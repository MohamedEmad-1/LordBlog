---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import InkReveal3 from "@/components/InkReveals/InkReveal3";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const BASE_URL = import.meta.env.BASE_URL;

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const scrollTargetId =
  featuredPosts.length > 0
    ? "featured"
    : recentPosts.length > 0
      ? "recent-posts"
      : "main-content";
---

<Layout>
  <InkReveal3
    client:only="react"
    zIndex={0}
    completionEventName="inkreveal:home:done"
    sessionSkipKey="inkreveal:home:played"
  />
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section
      id="hero"
      class:list={[
        "relative flex items-center justify-center border-b border-border",
      ]}
    >
      <div class="mx-auto max-w-2xl text-center">
        <h1 class="text-4xl font-bold sm:text-6xl">Lord | Logs Of A Random Dev</h1>
        <p class="mt-4 text-base sm:text-lg">
          The technical diary of Evelx. Exploring the intersection of luxury design, modern frameworks, and the hardware that powers them. Whether it’s comparing the latest dev environments or stress-testing new silicon, Lord goes beyond the agency work to provide raw reviews and random logs. Premium builds, honest gear talk, zero fluff.
          <a
            target="_blank"
            href={`${BASE_URL.endsWith("/") ? BASE_URL : BASE_URL + "/"}rss.xml`}
            class="hero-rss"
            aria-label="rss feed"
            title="RSS Feed"
          >
            <IconRss
              width={20}
              height={20}
              class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
            />
            <span class="sr-only">RSS Feed</span>
          </a>
        </p>
      </div>

      {
        // only display if at least one social link is enabled
        SOCIALS.length > 0 && (
          <div class="hero-socials-wrap">
            <Socials vertical class="hero-socials" aria-label="Social links" />
          </div>
        )
      }

      <a href={`#${scrollTargetId}`} class="scroll-cue" aria-label="Scroll down">
        <span class="scroll-cue__dot" aria-hidden="true"></span>
      </a>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Recent Posts</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href={`${BASE_URL.endsWith("/") ? BASE_URL : BASE_URL + "/"}posts/`}>
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  (() => {
    const setupHomeRevealLock = () => {
      const mainContent = document.querySelector("#main-content") as HTMLElement | null;
      const indexLayout = mainContent?.dataset?.layout;
      if (!indexLayout) return;

      sessionStorage.setItem("backUrl", import.meta.env.BASE_URL);

      const htmlEl = document.documentElement;
      const bodyEl = document.body;
      const pendingClass = "inkreveal-pending";
      const doneClass = "inkreveal-done";
      const revealSessionKey = "inkreveal:home:played";
      const revealAlreadyPlayed = sessionStorage.getItem(revealSessionKey) === "1";

      // Clean any previous controller left by page transitions.
      if ((window as any).__inkRevealHomeCleanup) {
        (window as any).__inkRevealHomeCleanup();
      }

      let unlocked = false;
      let timeoutId = 0;

      const lockScroll = () => {
        htmlEl.style.overflow = "hidden";
        bodyEl.style.overflow = "hidden";
        bodyEl.style.touchAction = "none";
        bodyEl.classList.add(pendingClass);
        bodyEl.classList.remove(doneClass);
      };

      const unlockScroll = () => {
        if (unlocked) return;
        unlocked = true;

        htmlEl.style.overflow = "";
        bodyEl.style.overflow = "";
        bodyEl.style.touchAction = "";
        bodyEl.classList.remove(pendingClass);
        bodyEl.classList.add(doneClass);

        window.removeEventListener("inkreveal:home:done", onRevealDone);
        document.removeEventListener("astro:before-swap", onBeforeSwap as EventListener);
        window.removeEventListener("pagehide", onPageHide);
        document.removeEventListener("click", onNavIntent, true);
        if (timeoutId) window.clearTimeout(timeoutId);
      };

      const onRevealDone = () => unlockScroll();
      const onBeforeSwap = () => unlockScroll();
      const onPageHide = () => unlockScroll();
      const onNavIntent = (event: Event) => {
        const target = event.target as HTMLElement | null;
        const link = target?.closest?.("a[href]") as HTMLAnchorElement | null;
        if (!link) return;
        const href = link.getAttribute("href") || "";
        if (!href || href.startsWith("#")) return;
        unlockScroll();
      };

      // Lock immediately when home is mounted, before reveal start.
      if (revealAlreadyPlayed) {
        unlockScroll();
        return;
      }

      lockScroll();

      window.addEventListener("inkreveal:home:done", onRevealDone, { once: true });
      document.addEventListener("astro:before-swap", onBeforeSwap as EventListener);
      window.addEventListener("pagehide", onPageHide);
      document.addEventListener("click", onNavIntent, true);

      // Fallback unlock in case the client component fails to initialize.
      timeoutId = window.setTimeout(unlockScroll, 12000);

      (window as any).__inkRevealHomeCleanup = unlockScroll;
    };

    // Run now and also after Astro navigation swaps.
    setupHomeRevealLock();
    document.addEventListener("astro:page-load", setupHomeRevealLock);
  })();
</script>

<style>
  :global(body) {
    --reveal-bounce: linear(
      0,
      0.013 0.6%,
      0.05 1.2%,
      0.2 2.5%,
      0.949 6.7%,
      1.2 8.4%,
      1.286 9.2%,
      1.35 10%,
      1.392 10.8%,
      1.411 11.6%,
      1.411 12.2%,
      1.401 12.8%,
      1.343 14.2%,
      1.258 15.5%,
      1.016 18.7%,
      0.914 20.4%,
      0.856 21.9%,
      0.831 23.5%,
      0.834 24.7%,
      0.858 26.1%,
      0.996 30.7%,
      1.037 32.4%,
      1.06 33.9%,
      1.07 35.4%,
      1.061 37.7%,
      0.989 43.8%,
      0.971 47.2%,
      1.012 59.1%,
      0.995 70.8%,
      1
    );
    --hero-glow: color-mix(in oklab, currentColor 30%, transparent);
    --hero-glow-soft: color-mix(in oklab, currentColor 14%, transparent);
  }

  :global(body) {
    background: transparent;
  }

  :global(header),
  :global(main),
  :global(footer) {
    position: relative;
    z-index: 2;
  }

  #hero {
    min-height: calc(100svh - 5.75rem);
    padding: 1rem 0 4.5rem;
  }

  #hero h1 {
    text-shadow:
      0 0 0.28rem color-mix(in oklab, currentColor 18%, transparent),
      0 0 0.55rem color-mix(in oklab, currentColor 12%, transparent);
  }

  :global(.hero-socials a),
  :global(.hero-socials svg) {
    filter: drop-shadow(0 0 0.28rem color-mix(in oklab, currentColor 18%, transparent));
  }

  :global(#top-nav-wrap a),
  :global(#top-nav-wrap button),
  :global(#top-nav-wrap svg) {
    transition:
      text-shadow 220ms ease,
      filter 220ms ease,
      color 220ms ease,
      stroke 220ms ease;
  }

  :global(#top-nav-wrap a:hover),
  :global(#top-nav-wrap button:hover),
  :global(#top-nav-wrap a.active-nav),
  :global(#top-nav-wrap .active-nav) {
    text-shadow:
      0 0 0.16rem color-mix(in oklab, currentColor 16%, transparent),
      0 0 0.42rem color-mix(in oklab, currentColor 10%, transparent);
  }

  :global(#top-nav-wrap a:hover svg),
  :global(#top-nav-wrap button:hover svg),
  :global(#top-nav-wrap .active-nav svg) {
    filter: drop-shadow(0 0 0.16rem color-mix(in oklab, currentColor 15%, transparent));
  }

  .hero-socials-wrap {
    position: absolute;
    right: 0.25rem;
    bottom: 1.25rem;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.45rem;
  }

  .hero-socials {
    padding: 0.45rem;
  }

  .hero-rss {
    display: inline-flex;
    vertical-align: middle;
    margin-inline-start: 0.35rem;
    opacity: 0;
    transform: translateY(1.4rem) scale(0.92);
    transition:
      opacity 1000ms var(--reveal-bounce) 50ms,
      transform 1000ms var(--reveal-bounce) 50ms;
  }

  :global(body.inkreveal-done) .hero-rss {
    opacity: 1;
    transform: translateY(-0.1rem) scale(1);
  }

  :global(#top-nav-wrap),
  #hero {
    border-color: transparent;
  }

  :global(#top-nav-wrap)::after,
  #hero::after {
    content: "";
    position: absolute;
    right: 0;
    bottom: -1px;
    left: 0;
    height: 1px;
    background: var(--color-border);
    opacity: 0;
    transform: translateY(1.4rem) scaleY(0.9);
    transform-origin: center;
    transition:
      opacity 1000ms var(--reveal-bounce) 50ms,
      transform 1000ms var(--reveal-bounce) 50ms;
    pointer-events: none;
  }

  :global(body.inkreveal-done #top-nav-wrap)::after,
  :global(body.inkreveal-done) #hero::after {
    opacity: 1;
    transform: translateY(0) scaleY(1);
  }

  .scroll-cue {
    position: absolute;
    left: 50%;
    bottom: 0.75rem;
    width: 2rem;
    height: 3.25rem;
    transform: translateX(-50%) translateY(1.4rem);
    border: 2px solid var(--color-foreground);
    border-radius: 999px;
    display: inline-flex;
    justify-content: center;
    align-items: flex-start;
    padding-top: 0.55rem;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 1000ms var(--reveal-bounce) 50ms,
      transform 1000ms var(--reveal-bounce) 50ms;
  }

  :global(body.inkreveal-done) .scroll-cue {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }

  .scroll-cue__dot {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 999px;
    background: var(--color-foreground);
    animation: scrollDot 1.6s ease-in-out infinite;
  }

  @keyframes scrollDot {
    0% {
      opacity: 0;
      transform: translateY(0);
    }
    25% {
      opacity: 1;
    }
    100% {
      opacity: 0;
      transform: translateY(1.35rem);
    }
  }

  @media (max-width: 640px) {
    #hero {
      min-height: calc(100svh - 5.25rem);
      padding-bottom: 4.75rem;
    }

    .hero-socials-wrap {
      right: 0;
      bottom: 1rem;
    }

    .scroll-cue {
      bottom: 0.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-cue__dot {
      animation: none;
    }
  }
</style>
